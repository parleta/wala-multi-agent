FROM python:3.11-slim

WORKDIR /app

# Copy the AZTM package
COPY aztm /app/aztm
COPY pyproject.toml /app/

# Install dependencies  
RUN pip install --no-cache-dir -e . && \
    pip install --no-cache-dir fastapi uvicorn

# Copy the demo server script
COPY docker/server_demo.py /app/

# Environment variables for AZTM credentials
ENV JID=aztmapi@sure.im
ENV PASSWORD=12345678
ENV PYTHONUNBUFFERED=1

# No ports exposed - server communicates only via messaging!

# Run the server demo
CMD ["python", "server_demo.py"]