FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Copy the entire aztm package
COPY aztm /app/aztm
COPY pyproject.toml /app/
COPY README.md /app/

# Install AZTM and dependencies
RUN pip install --no-cache-dir -e . && \
    pip install --no-cache-dir uvicorn[standard]

# Copy server example
COPY examples/docker/server /app/server

# Expose port (optional, since we're using XMPP)
EXPOSE 8000

# Run the server
CMD ["python", "/app/server/demo_server.py"]